{"config":{"lang":["zh","en","ja"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"]},"docs":[{"location":"","title":"Leo Tian\u7684\u4e2a\u4eba\u7f51\u7ad9","text":"<p>\u70b9\u51fb\u4e0a\u65b9Tags\u4ee5\u5f00\u59cb.</p> <p>\u7f51\u7ad9\u8fd8\u6709\u5927\u91cf\u5185\u5bb9\u7b49\u5f85\u6574\u7406...</p>"},{"location":"aesthetics/","title":"\u7f8e\u611f","text":"<p>\u70b9\u51fb\u5de6\u4fa7\u76ee\u5f55\u6253\u5f00\u6587\u7ae0</p>"},{"location":"aesthetics/%E5%8C%96%E5%AD%A6%E5%91%A8%E6%9C%9F%E8%A1%A8/","title":"\u5316\u5b66\u5468\u671f\u8868\uff08?\uff09","text":"<p>\u53ef\u4ee5\u53c2\u89c1\u6211\u7684\u4e00\u6761B\u7ad9\u52a8\u6001\uff1a</p> <p>\u94fe\u63a5</p>"},{"location":"aesthetics/%E6%96%87%E5%AD%97/","title":"\u6587\u5b57","text":"<p>\u5f85\u6574\u7406\u3002</p>"},{"location":"aesthetics/%E6%96%87%E5%AD%97/%E5%81%87%E5%B1%B1/","title":"\u5047\u5c71","text":""},{"location":"aesthetics/%E6%96%87%E5%AD%97/%E5%86%99%E4%BD%9C%E7%BB%83%E4%B9%A0-%E9%95%BF%E9%95%BF%E7%9A%84%E5%8F%A5%E5%AD%90/","title":"\u5199\u4f5c\u7ec3\u4e60 \u957f\u957f\u7684\u53e5\u5b50","text":""},{"location":"aesthetics/%E6%96%87%E5%AD%97/%E5%9B%BE%E4%B9%A6%E9%A6%86%E7%9F%A5%E9%81%93/","title":"\u56fe\u4e66\u9986\u77e5\u9053","text":""},{"location":"aesthetics/%E8%8B%B1%E6%96%87%E5%AD%97%E4%BD%93/%E5%A4%B4%E9%A5%B0%E4%BD%93/","title":"\u5934\u9970\u4f53","text":""},{"location":"aesthetics/%E8%8B%B1%E6%96%87%E5%AD%97%E4%BD%93/%E5%A4%B4%E9%A5%B0%E4%BD%93/#_2","title":"\u6837\u5f0f","text":"<p> i love you as well</p> <p>\u8fd9\u4e2a\u5b57\u4f53\u662f\u8bbe\u8ba1\u4e86\u6807\u70b9\u7684</p> <p> the quick brown fox,jumps over a \"lazy\" dog???</p> <p>\u53e5\u672b\u7684\u95ee\u53f7\u786e\u5b9e\u662f\u4e09\u4e2a\uff0c\u6709\u51e0\u4e2a\u70b9\u513f\u5c31\u662f\u51e0\u4e2a\u95ee\u53f7\u3002</p>"},{"location":"aesthetics/%E8%8B%B1%E6%96%87%E5%AD%97%E4%BD%93/%E5%A4%B4%E9%A5%B0%E4%BD%93/#_3","title":"\u7075\u611f","text":"<p>\u6765\u6e90\u81f3\u5c11\u6709\u4e09\u4e2a\uff1a</p> <ul> <li>\u5934\u9970\uff1a</li> </ul> <p>\u5c31\u50cf\u662f\u5b57\u4f53\u7684\u540d\u5b57\uff0c\u7f8e\u611f\u65e0\u9700\u591a\u8a00\uff1a</p> <p>\u70b9\u51fb\u770b\u56fe\uff08\u5916\u94fe\uff09 \u70b9\u51fb\u770b\u56fe\uff08\u5916\u94fe\uff09</p> <p>\u8fd9\u4e24\u4e2a\u662f\u4e2d\u5f0f\u7684\uff0c\u4e00\u4e2a\u5c11\u6570\u6c11\u65cf\u98ce\u683c\uff0c\u4e00\u4e2a\u662f\u6838\u5fc3\u98ce\u683c\u5427\u3002\u897f\u5f0f\u7684\u4e5f\u6709\u5f88\u591a\u534e\u4e3d\u7684\u5934\u9970\uff0c\u4e0d\u9700\u8981\u56fe\u7247\u4e5f\u80fd\u5f88\u597d\u8bf4\u660e\u3002</p> <ul> <li>\u5386\u53f2\u4e0a\u7684\u6587\u5b57\uff1a</li> </ul> <p>\u6709\u7684\u6587\u5b57\u597d\u50cf\u4e0d\u592a\u9002\u5408\u8d34\u51fa\u6765\uff08\uff09\u603b\u4e4b\uff0c\u5386\u53f2\u4e0a\u786e\u5b9e\u6709\u5f88\u591a\u7ad6\u5199\u7684\u6587\u5b57\uff0c\u5176\u5b9e\u53e4\u4ee3\u65f6\u5019\u4e2d\u6587\u5c31\u662f\u7ad6\u5199\u561b~\u4e0d\u8fc7\u4e2d\u6587\u6bcf\u4e2a\u5355\u8bcd\u4e4b\u95f4\u6709\u7f1d\u9699\uff0c\u56e0\u4e3a\u5355\u8bcd\u662f\u6709\u4e00\u4e2a\u6216\u8005\u591a\u4e2a\u6c49\u5b57\u7ec4\u6210\u7684\u3002\u4e5f\u6709\u97f3\u7d20\u6587\u5b57\u662f\u7ad6\u5199\u7684\uff0c\u800c\u4e14\u6bcf\u4e2a\u5355\u8bcd\u5185\u90e8\u94fe\u63a5\uff0c\u5916\u90e8\u5206\u79bb\uff0c\u6700\u7ecf\u5178\u7684\u5c31\u662f\u6ee1\u6587\u3002</p> <p>\u4e0d\u8fc7\u4e0d\u8bba\u662f\u4ec0\u4e48\u6837\u7684\u4e66\u5199\u7cfb\u7edf\uff0c\u5355\u8bcd\u548c\u53e5\u5b50\u4e66\u5199\u65b9\u5411\u90fd\u662f\u4e00\u81f4\u7684\uff0c\u800c\u8fd9\u4e2a\u5b57\u4f53\u610f\u5728\u6253\u7834\u8fd9\u79cd\u9650\u5236\u2014\u2014\u2014\u2014\u5355\u8bcd\u7ad6\u5199\uff0c\u53e5\u5b50\u6a2a\u5199\u3002</p> <ul> <li>\u5404\u79cd\u88c5\u9970\u54c1\uff1a</li> </ul> <p>\u6bd4\u5982\u8bf4\u98ce\u94c3\uff1a \u70b9\u51fb\u770b\u56fe\uff08\u5916\u94fe\uff09 \u70b9\u51fb\u770b\u56fe\uff08\u5916\u94fe\uff09 \u70b9\u51fb\u770b\u56fe\uff08\u5916\u94fe\uff09</p> <p>\u8bb8\u613f\u7b7e\u513f\uff1a \u70b9\u51fb\u770b\u56fe\uff08\u5916\u94fe\uff09</p> <p>\u6355\u68a6\u7f51\uff1a \u70b9\u51fb\u770b\u56fe\uff08\u5916\u94fe\uff09</p> <p>\u5404\u79cd\u5404\u79cd\u5427\uff1a \u70b9\u51fb\u770b\u56fe\uff08\u5916\u94fe\uff09</p>"},{"location":"aesthetics/%E8%8B%B1%E6%96%87%E5%AD%97%E4%BD%93/%E7%B1%BB%E7%BC%85%E4%BD%93/","title":"\u7c7b\u7f05\u4f53","text":""},{"location":"aesthetics/%E8%8B%B1%E6%96%87%E5%AD%97%E4%BD%93/%E7%B1%BB%E7%BC%85%E4%BD%93/#_2","title":"\u6837\u5f0f","text":"<p> the quick brown fox jumps over a lazy dog</p>"},{"location":"aesthetics/%E8%8B%B1%E6%96%87%E5%AD%97%E4%BD%93/%E7%B1%BB%E7%BC%85%E4%BD%93/#_3","title":"\u7075\u611f","text":"<p>\u6765\u81ea\u7f05\u7538\u8bed\u4e66\u5199\u7cfb\u7edf\u3002</p>"},{"location":"aesthetics/%E8%8B%B1%E6%96%87%E5%AD%97%E4%BD%93/%E8%89%B2%E5%BD%A9%E4%BD%93/","title":"\u8272\u5f69\u4f53","text":""},{"location":"aesthetics/%E8%8B%B1%E6%96%87%E5%AD%97%E4%BD%93/%E8%89%B2%E5%BD%A9%E4%BD%93/#_2","title":"\u6837\u5f0f","text":"<p> abcdefghijklmnopqrstuvwxyz</p>"},{"location":"aesthetics/%E8%8B%B1%E6%96%87%E5%AD%97%E4%BD%93/%E8%89%B2%E5%BD%A9%E4%BD%93/#_3","title":"\u7075\u611f","text":"<p>\u5c0f\u65f6\u5019\u4e00\u76f4\u89c9\u5f97\u6570\u5b57\u548c\u5b57\u6bcd\u90fd\u662f\u6709\u989c\u8272\u7684\u3002\u6bd4\u5982\u8bf4A\u5c31\u662f\u7ea2\u8272\u7684\uff0cB\u5c31\u662f\u84dd\u8272\u7684\uff0cC\u662f\u9ec4\u8272\u7684\u3002</p> <p>\u540e\u6765\u5f97\u77e5\uff0c\u8fd9\u79cd\u611f\u89c9\u5176\u5b9e\u662f\u88ab\u5b66\u8005\u4eec\u6ce8\u610f\u8fc7\u7684\uff0c\u8fd9\u79cd\u73b0\u8c61\u53eb\u505a\u201c\u8054\u89c9\u201d\u3002</p> <p>\u7075\u611f\u5c31\u662f\uff0c\u80fd\u4e0d\u80fd\u653e\u5f03\u6240\u6709\u7684\u5f2f\u5f2f\u7ed5\u7ed5\uff0c\u53ea\u4f7f\u7528\u5fc3\u4e2d\u7684\u611f\u89c9\uff0c\u8fd8\u6709\u5b57\u6bcd\u5360\u5730\u7684\u5927\u5c0f\uff0c\u5fc5\u8981\u7684\u65f6\u5019\u4f7f\u7528\u4e00\u4e9b\u6307\u793a\u7b26\u53f7\uff08\u6bd4\u5982n\u548cm\u4f7f\u7528\u4e86\u4e00\u4e2a~\u5f62\uff0c\u5176\u5b9e\u662f\u4e00\u4e2a\u8f83\u4e3a\u901a\u7528\u7684\u9f3b\u5316\u7b26\u53f7\uff09\uff0c\u6765\u8868\u8fbe\u4e00\u4e2a\u5b57\u6bcd\uff1f</p> <p>\u770b\u8d77\u6765\u53ef\u4ee5\u3002</p>"},{"location":"linguistics/","title":"\u8bed\u8a00\u5b66","text":"<p>\u70b9\u51fb\u5de6\u4fa7\u76ee\u5f55\u6253\u5f00\u6587\u7ae0</p>"},{"location":"linguistics/%E8%8B%B1%E8%AF%AD%E8%AF%8D%E6%BA%90/","title":"\u82f1\u8bed\u8bcd\u6e90","text":"<p>\u6ce8\u610f\u8fd9\u91cc\u4e0d\u662f\u82f1\u8bed\u8bcd\u6e90\u7406\u8bba\uff0c\u800c\u662f\u5177\u4f53\u7684\u82f1\u8bed\u8bcd\u6e90\u3002</p> <p>\u5173\u4e8e\u82f1\u8bed\u8bcd\u6e90\u7406\u8bba\uff0c\u8fd9\u91cc\u6ca1\u6709\u4ec0\u4e48\u8d44\u6599\uff0c\u6211\u4e5f\u6ca1\u6709\u7cfb\u7edf\u5b66\u4e60\u8fc7\uff0c\u4f46\u662f\u5e73\u65f6\u96f6\u6563\u5730\u8fb9\u770b\u8fb9\u4e86\u89e3\u3002</p> <p>\u81f3\u4e8e\u8fd9\u91cc\u5177\u4f53\u7684\u82f1\u8bed\u8bcd\u6e90\u6765\u81ea\u54ea\u91cc\uff1a</p> <p>\u91cc\u9762\u5f88\u591a\u5185\u5bb9\u6765\u81ea\u8da3\u8bcd\u8bcd\u5178\u6216\u8005\u4f18\u8bcd\u8bcd\u5178\uff0c\u6211\u5230\u73b0\u5728\u4e5f\u4e0d\u77e5\u9053\u8fd9\u4e24\u4e2a\u7f51\u7ad9\u7684\u8d44\u6599\u6765\u81ea\u54ea\u91cc\uff0c\u4e5f\u4e0d\u77e5\u9053\u8fd9\u4e24\u4e2a\u7c7b\u4f3c\u7684\u7f51\u7ad9\u662f\u4ec0\u4e48\u5173\u7cfb\u3002</p> <p>\u540e\u6765\u663e\u800c\u6613\u89c1\u7684\u662f\u8fd9\u4e24\u4e2a\u7f51\u7ad9\u5f88\u591a\u8bcd\u6e90\u662f\u9519\u7684\u3002\u7cbe\u4fee\u7684\u8fc7\u7a0b\u4e2d\u5c31\u7528\u5230\u53e6\u4e00\u4e2a\u91cd\u8981\u7684\u7f51\u7ad9Online Etymology Dictionary\uff0c\u597d\u50cf\u662f\u4e2a\u8be5\u9886\u57df\u7ecf\u5178\u7f51\u7ad9\u3002</p> <p>\u518d\u6709\u4e0d\u6e05\u695a\u7684\uff0c\u5c31\u662f\u5f88\u5c11\u7528\u7684\uff0c\u76f4\u63a5\u53bb\u7ef4\u57fa\u8bcd\u5178\u4e86\u3002</p> <p>\u4e2d\u5b66\u65f6\u5019\u65e0\u6570\u4e2a\u5468\u672b\u7684\u4e0b\u5348\u90fd\u5728\u8fd9\u51e0\u4e2a\u7f51\u7ad9\u3001\u5e55\u5e03\u3001PyCharm\u3001\u8bb0\u4e8b\u672c\u4e2d\u6765\u56de\u5207\u6362\u5728\u8bcd\u6c47\u7684\u6d77\u6d0b\u4e2d\uff0c\u603b\u4e4b\u6700\u540e\u7684\u6210\u679c\u8fd8\u662f\u4ee4\u4eba\u6b23\u6170\u7684\uff0c\u6bcf\u6b21\u5f52\u7eb3\u90fd\u5c0f\u5c0f\u611f\u53f9\u600e\u4e48\u8fd9\u4e48\u591a\u771f\u96be\u6574\u7406\uff08\uff09</p>"},{"location":"linguistics/%E8%8B%B1%E8%AF%AD%E8%AF%8D%E6%BA%90/%E4%B8%93%E9%A1%B9%E9%A1%B9%E7%9B%AE/PIE-per/","title":"PIE per","text":"<p>\u8fd9\u4e2a\u662f\u4e00\u4e2a\u77e5\u540dPIE\u8bcd\u6839\uff0c\u5404\u4e2a\u610f\u601d\u4e4b\u95f4\u6709\u65f6\u5019\u4f1a\u88ab\u8ba4\u4e3a\u662f\u540c\u6e90\u7684\uff0c\u800c\u4e14\u884d\u751f\u8bcd\u8fc7\u4e8e\u591a\uff0c\u6240\u4ee5\u5355\u5f00\u4e00\u4e2a\u6587\u4ef6\u3002</p>"},{"location":"linguistics/%E8%8B%B1%E8%AF%AD%E8%AF%8D%E6%BA%90/%E4%B8%93%E9%A1%B9%E9%A1%B9%E7%9B%AE/PIE-pere/","title":"PIE pere","text":"<p>\u8fd9\u4e2a\u6709\u65f6\u5019\u88ab\u8ba4\u4e3a\u548cPIE*per\u540c\u6e90\uff0c\u59d1\u4e34\u65f6\u8fd9\u6837\u6574\u7406\u3002</p>"},{"location":"linguistics/%E8%8B%B1%E8%AF%AD%E8%AF%8D%E6%BA%90/%E4%B8%93%E9%A1%B9%E9%A1%B9%E7%9B%AE/%E4%B8%80%E7%BD%91%E7%AB%99%E7%9A%84onomatopoeia/","title":"\u4e00\u7f51\u7ad9\u7684onomatopoeia","text":""},{"location":"linguistics/%E8%8B%B1%E8%AF%AD%E8%AF%8D%E6%BA%90/%E4%B8%93%E9%A1%B9%E9%A1%B9%E7%9B%AE/%E5%85%83%E7%B4%A0%E8%AF%8D%E6%BA%90/","title":"\u5143\u7d20\u8bcd\u6e90","text":""},{"location":"linguistics/%E8%8B%B1%E8%AF%AD%E8%AF%8D%E6%BA%90/%E4%B8%93%E9%A1%B9%E9%A1%B9%E7%9B%AE/%E5%85%83%E7%B4%A0%E8%AF%8D%E6%BA%90%E7%9A%84%E5%88%86%E7%B1%BB/","title":"\u5143\u7d20\u8bcd\u6e90\u7684\u5206\u7c7b","text":""},{"location":"linguistics/%E8%8B%B1%E8%AF%AD%E8%AF%8D%E6%BA%90/%E4%B8%93%E9%A1%B9%E9%A1%B9%E7%9B%AE/%E6%9C%89%E8%B6%A3%E7%9A%84%E4%B8%93%E9%A2%98/","title":"\u6709\u8da3\u7684\u4e13\u9898","text":""},{"location":"linguistics/%E8%8B%B1%E8%AF%AD%E8%AF%8D%E6%BA%90/%E4%B8%93%E9%A1%B9%E9%A1%B9%E7%9B%AE/%E6%9C%89%E8%B6%A3%E7%9A%84%E4%B8%93%E9%A2%982/","title":"\u6709\u8da3\u7684\u4e13\u98982","text":""},{"location":"linguistics/%E8%8B%B1%E8%AF%AD%E8%AF%8D%E6%BA%90/%E4%B8%93%E9%A1%B9%E9%A1%B9%E7%9B%AE/%E6%9